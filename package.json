{
  "name": "web3-wallet",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "pnpm": {
    "overrides": {
      "glob": "^10.5.0"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "android:env": "bash scripts/check-android-build-env.sh",
    "android:install-env": "bash scripts/install-android-build-env.sh",
    "android:install-env:init": "bash scripts/install-android-build-env.sh --init-project",
    "android:release": "bash ./build_apk",
    "android:keystore": "bash scripts/generate-android-keystore.sh",
    "android:sign": "bash scripts/sign-android-apk.sh",
    "test": "pnpm test:rust && pnpm test:unit",
    "test:rust": "cargo test -q --manifest-path src-tauri/Cargo.toml",
    "test:security": "pnpm test:rust && pnpm test:unit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@tauri-apps/plugin-stronghold": "~2.3.1",
    "pinia": "^3.0.4",
    "qrcode": "^1.5.4",
    "viem": "^2.47.6",
    "vue": "^3.5.31",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.0",
    "@tauri-apps/cli": "^2.10.1",
    "@types/qrcode": "^1.5.6",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.2",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^29.0.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.5",
    "vitest": "^4.1.2",
    "vue-tsc": "^3.2.6"
  }
}

#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$SCRIPT_DIR"

DEFAULT_KEYSTORE_PATH="$PROJECT_ROOT/.local/android-upload.keystore"
DEFAULT_KEY_ALIAS="upload"
DEFAULT_RELEASE_DIR="$PROJECT_ROOT/release"
DEFAULT_BUILD_TARGET="aarch64"
APK_OUTPUT_DIR="$PROJECT_ROOT/src-tauri/gen/android/app/build/outputs/apk"
TAURI_CONFIG_PATH="$PROJECT_ROOT/src-tauri/tauri.conf.json"
PACKAGE_JSON_PATH="$PROJECT_ROOT/package.json"

KEYSTORE_PATH="${ANDROID_KEYSTORE_PATH:-$DEFAULT_KEYSTORE_PATH}"
KEY_ALIAS="${ANDROID_KEY_ALIAS:-$DEFAULT_KEY_ALIAS}"
RELEASE_DIR="${ANDROID_RELEASE_DIR:-$DEFAULT_RELEASE_DIR}"
BUILD_TARGET="${ANDROID_BUILD_TARGET:-$DEFAULT_BUILD_TARGET}"
AUTO_VERSION_BUMP="${ANDROID_AUTO_VERSION_BUMP:-1}"
ALLOW_NEW_KEYSTORE="${ALLOW_NEW_KEYSTORE:-0}"
STORE_PASSWORD="${ANDROID_KEYSTORE_PASSWORD:-}"
KEY_PASSWORD="${ANDROID_KEY_PASSWORD:-}"
STORE_PASSWORD_FILE="${ANDROID_KEYSTORE_PASSWORD_FILE:-}"
KEY_PASSWORD_FILE="${ANDROID_KEY_PASSWORD_FILE:-}"
CREATE_KEYSTORE=0

usage() {
  cat <<'EOF'
Usage:
  ./build_apk [options]

Options:
  --target TARGET       Android build target, default: aarch64
  --universal           Build all ABIs into a universal APK
  --no-version-bump     Keep the current app version instead of incrementing it
  --create-keystore     Allow minting a new release keystore when none exists
  --release-dir PATH    Directory to copy the final APK into
  --help                Show this help

Environment variables:
  ANDROID_KEYSTORE_PATH
  ANDROID_KEY_ALIAS
  ANDROID_KEYSTORE_PASSWORD
  ANDROID_KEY_PASSWORD
  ANDROID_KEYSTORE_PASSWORD_FILE
  ANDROID_KEY_PASSWORD_FILE
  ANDROID_RELEASE_DIR
  ANDROID_BUILD_TARGET
  ANDROID_AUTO_VERSION_BUMP
  ALLOW_NEW_KEYSTORE
EOF
}

is_truthy() {
  local value="${1:-}"
  value="${value,,}"
  case "$value" in
    1|true|yes|on)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

read_secret_from_file() {
  local file_path="$1"
  [[ -f "$file_path" ]] || {
    printf 'Secret file not found: %s\n' "$file_path" >&2
    exit 1
  }
  IFS= read -r secret < "$file_path" || true
  printf '%s' "$secret"
}

read_app_version() {
  node -e 'const fs=require("fs"); const cfg=JSON.parse(fs.readFileSync(process.argv[1], "utf8")); console.log((cfg.version || "0.0.0").replace(/[^A-Za-z0-9._-]+/g, "-"));' "$TAURI_CONFIG_PATH"
}

bump_app_version() {
  node - "$TAURI_CONFIG_PATH" "$PACKAGE_JSON_PATH" <<'NODE'
const fs = require('fs');

const [tauriConfigPath, packageJsonPath] = process.argv.slice(2);

function readJson(filePath) {
  return JSON.parse(fs.readFileSync(filePath, 'utf8'));
}

function writeJson(filePath, data) {
  fs.writeFileSync(filePath, `${JSON.stringify(data, null, 2)}\n`);
}

function bumpTrailingNumber(version) {
  const match = String(version).match(/^(.*?)(\d+)$/);
  if (!match) {
    throw new Error(`Version must end with a number: ${version}`);
  }

  const [, prefix, numericSuffix] = match;
  const nextSuffix = (BigInt(numericSuffix) + 1n).toString();
  const paddedNextSuffix = numericSuffix.startsWith('0')
    ? nextSuffix.padStart(numericSuffix.length, '0')
    : nextSuffix;

  return `${prefix}${paddedNextSuffix}`;
}

const tauriConfig = readJson(tauriConfigPath);
const nextVersion = bumpTrailingNumber(tauriConfig.version || '0.0.0');
tauriConfig.version = nextVersion;
writeJson(tauriConfigPath, tauriConfig);

if (fs.existsSync(packageJsonPath)) {
  const packageJson = readJson(packageJsonPath);
  if (typeof packageJson.version === 'string') {
    packageJson.version = nextVersion;
    writeJson(packageJsonPath, packageJson);
  }
}

console.log(nextVersion);
NODE
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --target)
      BUILD_TARGET="$2"
      shift 2
      ;;
    --universal)
      BUILD_TARGET=""
      shift
      ;;
    --no-version-bump)
      AUTO_VERSION_BUMP=0
      shift
      ;;
    --create-keystore)
      CREATE_KEYSTORE=1
      shift
      ;;
    --release-dir)
      RELEASE_DIR="$2"
      shift 2
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      printf 'Unknown argument: %s\n' "$1" >&2
      usage >&2
      exit 1
      ;;
  esac
done

if ! command -v node >/dev/null 2>&1; then
  printf 'node not found in PATH\n' >&2
  exit 1
fi

if ! command -v pnpm >/dev/null 2>&1; then
  printf 'pnpm not found in PATH\n' >&2
  exit 1
fi

if [[ ! -f "$KEYSTORE_PATH" && $CREATE_KEYSTORE -eq 0 ]] && ! is_truthy "$ALLOW_NEW_KEYSTORE"; then
  printf 'Keystore not found: %s\n' "$KEYSTORE_PATH" >&2
  printf 'Refusing to mint a new release keystore implicitly.\n' >&2
  printf 'Run `pnpm android:keystore` first, or pass `--create-keystore` / `ALLOW_NEW_KEYSTORE=1` if you intentionally want a new signing identity.\n' >&2
  exit 1
fi

if [[ -z "$STORE_PASSWORD" ]]; then
  if [[ -n "$STORE_PASSWORD_FILE" ]]; then
    STORE_PASSWORD="$(read_secret_from_file "$STORE_PASSWORD_FILE")"
  fi
fi

if [[ -z "$STORE_PASSWORD" ]]; then
  read -r -s -p "Keystore password: " STORE_PASSWORD
  printf '\n'
fi

if [[ -z "$KEY_PASSWORD" ]]; then
  if [[ -n "$KEY_PASSWORD_FILE" ]]; then
    KEY_PASSWORD="$(read_secret_from_file "$KEY_PASSWORD_FILE")"
  fi
fi

if [[ -z "$KEY_PASSWORD" ]]; then
  read -r -s -p "Key password (press Enter to reuse keystore password): " KEY_PASSWORD
  printf '\n'
  if [[ -z "$KEY_PASSWORD" ]]; then
    KEY_PASSWORD="$STORE_PASSWORD"
  fi
fi

TMP_SECRET_DIR="$(mktemp -d)"
cleanup_secret_files() {
  rm -rf "$TMP_SECRET_DIR"
}
trap cleanup_secret_files EXIT

TMP_STORE_PASSWORD_FILE="$TMP_SECRET_DIR/keystore.pass"
TMP_KEY_PASSWORD_FILE="$TMP_SECRET_DIR/key.pass"
OLD_UMASK="$(umask)"
umask 077
printf '%s' "$STORE_PASSWORD" > "$TMP_STORE_PASSWORD_FILE"
printf '%s' "$KEY_PASSWORD" > "$TMP_KEY_PASSWORD_FILE"
umask "$OLD_UMASK"
unset STORE_PASSWORD KEY_PASSWORD STORE_PASSWORD_FILE KEY_PASSWORD_FILE

if [[ ! -f "$KEYSTORE_PATH" ]]; then
  printf 'Keystore not found. Creating: %s\n' "$KEYSTORE_PATH"
  ANDROID_KEYSTORE_PATH="$KEYSTORE_PATH" \
  ANDROID_KEY_ALIAS="$KEY_ALIAS" \
  ANDROID_KEYSTORE_PASSWORD_FILE="$TMP_STORE_PASSWORD_FILE" \
  ANDROID_KEY_PASSWORD_FILE="$TMP_KEY_PASSWORD_FILE" \
    bash "$PROJECT_ROOT/scripts/generate-android-keystore.sh" --out "$KEYSTORE_PATH" --alias "$KEY_ALIAS"
fi

APP_NAME="$(node -e 'const fs=require("fs"); const pkg=JSON.parse(fs.readFileSync(process.argv[1], "utf8")); console.log((pkg.name || "app").replace(/[^A-Za-z0-9._-]+/g, "-"));' "$PACKAGE_JSON_PATH")"
if is_truthy "$AUTO_VERSION_BUMP"; then
  APP_VERSION="$(bump_app_version)"
  printf 'App version bumped to %s\n' "$APP_VERSION"
else
  APP_VERSION="$(read_app_version)"
fi

BUILD_CMD=(pnpm tauri android build --apk)
TARGET_LABEL="universal"
declare -A BEFORE_BUILD_UNSIGNED_APKS=()

file_mtime_seconds() {
  local file_path="$1"
  stat -c %Y "$file_path" 2>/dev/null || stat -f %m "$file_path"
}

while IFS= read -r -d '' existing_apk; do
  BEFORE_BUILD_UNSIGNED_APKS["$existing_apk"]="$(file_mtime_seconds "$existing_apk")"
done < <(find "$APK_OUTPUT_DIR" -type f -name '*unsigned.apk' -print0 2>/dev/null)

if [[ -n "$BUILD_TARGET" ]]; then
  BUILD_CMD+=(--target "$BUILD_TARGET")
  case "$BUILD_TARGET" in
    aarch64)
      TARGET_LABEL="arm64"
      ;;
    armv7)
      TARGET_LABEL="armv7"
      ;;
    i686)
      TARGET_LABEL="x86"
      ;;
    x86_64)
      TARGET_LABEL="x86_64"
      ;;
    *)
      TARGET_LABEL="$BUILD_TARGET"
      ;;
  esac
fi

printf 'Building Android release APK'
if [[ -n "$BUILD_TARGET" ]]; then
  printf ' for target %s' "$BUILD_TARGET"
fi
printf '...\n'

bash "$PROJECT_ROOT/scripts/sync-android-system-bars.sh"

(
  cd "$PROJECT_ROOT"
  "${BUILD_CMD[@]}"
)

unsigned_candidates=()
while IFS= read -r -d '' candidate_apk; do
  current_mtime="$(file_mtime_seconds "$candidate_apk")"
  previous_mtime="${BEFORE_BUILD_UNSIGNED_APKS[$candidate_apk]:-}"
  if [[ -z "$previous_mtime" || "$current_mtime" -gt "$previous_mtime" ]]; then
    unsigned_candidates+=("$candidate_apk")
  fi
done < <(find "$APK_OUTPUT_DIR" -type f -name '*unsigned.apk' -print0 2>/dev/null)

if [[ ${#unsigned_candidates[@]} -eq 0 ]]; then
  printf 'Unsigned APK not found after build\n' >&2
  exit 1
fi

if [[ ${#unsigned_candidates[@]} -gt 1 ]]; then
  printf 'More than one unsigned APK changed during this build. Refusing to guess which artifact to sign:\n' >&2
  printf '  %s\n' "${unsigned_candidates[@]}" >&2
  exit 1
fi

UNSIGNED_APK="${unsigned_candidates[0]}"

mkdir -p "$RELEASE_DIR"

FINAL_APK="$RELEASE_DIR/${APP_NAME}-v${APP_VERSION}-android-${TARGET_LABEL}-release.apk"
LATEST_APK="$RELEASE_DIR/${APP_NAME}-android-release.apk"

ANDROID_KEYSTORE_PATH="$KEYSTORE_PATH" \
ANDROID_KEY_ALIAS="$KEY_ALIAS" \
ANDROID_KEYSTORE_PASSWORD_FILE="$TMP_STORE_PASSWORD_FILE" \
ANDROID_KEY_PASSWORD_FILE="$TMP_KEY_PASSWORD_FILE" \
  bash "$PROJECT_ROOT/scripts/sign-android-apk.sh" \
    --in "$UNSIGNED_APK" \
    --out "$FINAL_APK" \
    --ks "$KEYSTORE_PATH" \
    --alias "$KEY_ALIAS"

cp -f "$FINAL_APK" "$LATEST_APK"

printf '\nFinal APK:\n'
printf '  %s\n' "$FINAL_APK"
printf 'Latest copy:\n'
printf '  %s\n' "$LATEST_APK"
printf 'SHA256:\n'
sha256sum "$FINAL_APK"
